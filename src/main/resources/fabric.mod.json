{
  "schemaVersion": 1,
  "id": "fishtourn",
  "version": "${version}",
  "name": "Fishing Tournament",
  "description": "Fishing Tournament Mod for Droingo's Fishing Tournament",
  "authors": [
    "Droingo"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/Droingo/fishtourn"
  },
  "license": "MIT",
  "icon": "assets/fishtourn/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.droingo.fishtourn.FishingTournament"
    ],
    "fabric-datagen": [
      "net.droingo.fishtourn.FishingTournamentDataGenerator"
    ],
    "client": [
      "net.droingo.fishtourn.FishingTournamentClient"
    ]
  },
  "mixins": [
    "fishtourn.mixins.json",
    "fishtourn.client.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-api": "*"
  }
}